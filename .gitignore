# ── Data files (too large for GitHub) ──────────────────────────
data/raw/
data/processed/

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ─────────────────────────────────────────
venv/
env/

# ── Environment variables (contain secrets) ─────────────────────
.env
# NOTE: .env.example IS committed — it's a safe template with no real values

# ── Model artifacts (generated after training — large binary files) ─────────
# Ignore the binary model and plot images, but KEEP model_info.json
# so the /model-info API works immediately after cloning.
models/*.pkl
models/*.png

# NOTE: models/model_info.json IS committed intentionally — it contains
# only text metadata (accuracy, confusion matrix, feature importances)
# and is required by the FastAPI /model-info endpoint at startup.

# ── MLflow experiment tracking database ─────────────────────────
mlruns/mlflow.db
mlruns/artifacts/
# NOTE: mlruns/ directory itself is fine to track; only the .db and
# artifact blobs are excluded (they can be large and are re-generated).

# ── Jupyter ─────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Frontend ────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production

# NOTE: frontend/package-lock.json IS committed intentionally
# so collaborators get identical dependency versions on npm install

# ── Backend ─────────────────────────────────────────────────────
backend/__pycache__/
backend/routes/__pycache__/
backend/.env
# NOTE: backend/.env.example IS committed — safe template

# ── IDE ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
