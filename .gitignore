# ═══════════════════════════════════════════════════════════════════════════════
#  NIDS — Network Intrusion Detection System  |  .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Raw & processed datasets (too large for GitHub) ─────────────────────────
data/raw/
data/processed/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb
*.egg
*.egg-info/
dist/
build/
*.spec
.eggs/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Environment / secrets (NEVER commit these) ───────────────────────────────
.env
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production
# .env.example files ARE committed — they are safe templates with no real values

# ── Trained model binaries (large — generated by notebooks) ─────────────────
# Kept out of git; regenerate by running notebooks 02 + 03 in order.
models/*.pkl
models/*.png
models/*.jpg

# models/model_info.json     → IS committed (needed by /model-info API at boot)
# models/cicids_model_info.json → excluded until CICIDS pipeline is complete
models/cicids_model_info.json

# ── MLflow experiment tracking (local only) ──────────────────────────────────
mlruns/
mlartifacts/

# ── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Frontend — Node & build output ──────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.cache/
frontend/coverage/
# package-lock.json IS committed — ensures reproducible installs

# ── Backend pycache (each subfolder) ─────────────────────────────────────────
backend/__pycache__/
backend/routes/__pycache__/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Testing & coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Type checking / linting caches ───────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pyright/

# ── IDE & editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*~

# ── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Temporary files ──────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig
*.rej

# ── Distribution / packaging ─────────────────────────────────────────────────
MANIFEST
pip-wheel-metadata/
share/python-wheels/
