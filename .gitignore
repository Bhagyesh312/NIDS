# ── Data files (too large for GitHub) ──────────────────────────
data/raw/
data/processed/

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── Virtual environment ─────────────────────────────────────────
venv/
env/

# ── Environment variables (contain secrets) ─────────────────────
.env
# NOTE: .env.example IS committed — it's a safe template with no real values

# ── Model artifacts (generated after training — large binary files) ─────────
# Ignore the binary model and plot images, but KEEP model_info.json files
# so the /model-info API works immediately after cloning.
models/*.pkl
models/*.png

# NOTE: models/model_info.json IS committed — required by /model-info API at startup.
# models/cicids_model_info.json is excluded until CICIDS pipeline is complete.
models/cicids_model_info.json

# ── MLflow experiment tracking ──────────────────────────────────
# The entire mlruns/ folder is local-only — regenerated on each training run.
mlruns/

# ── Jupyter ─────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Frontend ────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.production

# NOTE: frontend/package-lock.json IS committed intentionally
# so collaborators get identical dependency versions on npm install

# ── Backend ─────────────────────────────────────────────────────
backend/__pycache__/
backend/routes/__pycache__/
backend/.env
# NOTE: backend/.env.example IS committed — safe template

# ── IDE ─────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.user

# ── OS ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
